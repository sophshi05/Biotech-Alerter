# Neon/Vercel Postgres connection string
# Local dev: copy from Neon dashboard or Vercel → Storage → your DB → .env.local
# Vercel: auto-injected when you link the Postgres store to your project
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: protect /api/refresh from being called by anyone
# Leave empty to allow unauthenticated refreshes
REFRESH_SECRET=
